# ForgeQuest Digital Factory — Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
HOST=0.0.0.0

# SMTP Email Settings (configure for production)
# Use a transactional email service like SendGrid, Mailgun, or Postmark
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=your-sendgrid-api-key
SMTP_PASS=your-sendgrid-api-key-value
EMAIL_FROM=noreply@forgequest.io

# Team DB (used by team-db CLI — set by platform)
# TEAM_DB_URL=libsql://...